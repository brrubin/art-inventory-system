CREATE TABLE artwork (
    id INTEGER PRIMARY KEY,
    title TEXT NOT NULL,
    artist TEXT NOT NULL,
    year INTEGER,
    medium TEXT,
    location TEXT,
    price REAL,
    image BLOB
);

CREATE INDEX idx_artwork_title ON artwork(title);
CREATE INDEX idx_artwork_artist ON artwork(artist);
CREATE INDEX idx_artwork_year ON artwork(year);
CREATE INDEX idx_artwork_location ON artwork(location);

